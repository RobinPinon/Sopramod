{
  "schemaVersion": 1,
  "id": "sopramod",
  "version": "${version}",
  "name": "SopraMod: Chaos Mod",
  "description": "SopraMod is a Chaos Mod where random events happens every 30 seconds. This mod includes Youtube/Twitch/Discord integration for voting events!",
  "authors": [
    "sopralus",
    "bl4ckscor3",
    "Kanawanagasaki",
    "slicedlime",
    "curio-sitas",
    "More contributors at GitHub!"
  ],
  "contact": {
    "homepage": "https://www.curseforge.com/minecraft/mc-mods/sopramod",
    "sources": "https://github.com/sopralus/SopraMod",
    "issues": "https://github.com/sopralus/SopraMod/issues"
  },
  "license": "GPL-3.0",
  "icon": "assets/sopramod/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "com.poc.sopramod.client.SopramodClient"
    ],
    "main": [
      "com.poc.sopramod.Sopramod"
    ],
    "modmenu": [
      "com.poc.sopramod.client.SopramodModMenu"
    ],
    "fabric-datagen": [
      "com.poc.sopramod.datagen.SopramodDataGen"
    ]
  },
  "mixins": [
    "sopramod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric": "*",
    "minecraft": ">=1.21.11"
  },
  "suggests": {
    "modmenu": ">=3.1.0"
